@using StudentManagement.MVC.Models.Departments
@model StudentManagement.MVC.Common.PagedResult<DepartmentVm>

@{
    ViewData["title"] = "Department List";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Danh sách phòng ban</h3>
        <p class="text-muted fs-7 mb-0">Quản lý, tìm kiếm và thao tác với dữ liệu sinh viên.</p>
    </div>
    <a class="btn btn-primary btn-lg custom-btn-submit px-4 fs-6" asp-action="Create" asp-controller="Department">
        <i class="bi bi-plus-lg me-2 fw-bold"></i> Thêm phòng ban
    </a>
</div>

<div class="card-dashboard mb-4 p-3">
    <form method="get" class="row g-3 align-items-center">
        <div class="col-md-4">
            <div class="input-icon">
                <i class="bi bi-search text-muted" style="position: absolute; left: 15px; top: 12px;"></i>
                <input type="text" name="Name" value="@ViewBag.Query?.Name"
                       class="form-control custom-input w-100 ps-5" placeholder="Nhập tên phòng ban cần tìm..." />
            </div>
        </div>

        <div class="col-md-6">
            <div class="d-flex flex-column flex-sm-row gap-2 align-items-center date-filter-group">
                <div class="d-flex align-items-center w-100">
                    <span class="text-muted fw-medium me-2 whitespace-nowrap" style="min-width: 70px;">Từ ngày:</span>
                    <input type="date" name="From" value="@ViewBag.Query?.From?.ToString("yyyy-MM-dd")"
                           class="form-control custom-input" />
                </div>
                <div class="d-flex align-items-center w-100 mt-2 mt-sm-0">
                    <span class="text-muted fw-medium me-2 whitespace-nowrap" style="min-width: 75px;">Đến ngày:</span>
                    <input type="date" name="To" value="@ViewBag.Query?.To?.ToString("yyyy-MM-dd")"
                           class="form-control custom-input" />
                </div>
            </div>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary custom-btn-submit w-100 py-2">
                <i class="bi bi-funnel me-1"></i> Lọc dữ liệu
            </button>
        </div>
    </form>
</div>

<div class="card-dashboard p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table custom-table align-middle mb-0" id="myTable">
            <thead>
                <tr>
                    <th class="ps-4" width="8%">ID</th>
                    <th width="20%">Tên phòng ban</th>
                    <th width="15%">Ngày tạo</th>
                    <th width="15%">Sửa đổi</th>
                    <th class="text-center" width="17%">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data != null)
                {
                    int index = 1;
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="text-muted fw-medium">@(index++)</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle-sm me-3 text-primary bg-primary-subtle fw-bold rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                        @(string.IsNullOrEmpty(item.Name) ? "U" : item.Name.Substring(0, 1).ToUpper())
                                    </div>
                                    <span class="fw-bold text-dark fs-6">@item.Name</span>
                                </div>
                            </td>
                            <td class="text-muted fs-7">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-muted fs-7">@item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Update" asp-controller="Department" asp-route-Id="@item.Id"
                                    class="btn btn-action btn-light text-warning" data-bs-toggle="tooltip" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-controller="Department" asp-route-Id="@item.Id"
                                    onclick="return confirm('Bạn có chắc chắn muốn xóa phòng ban này? Hành động này không thể hoàn tác.')"
                                    class="btn btn-action btn-light text-danger" data-bs-toggle="tooltip" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Chưa có dữ liệu sinh viên nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="px-4 py-3 border-top d-flex justify-content-between align-items-center bg-white">
            <span class="text-muted fs-7">
                Trang @Model.PageNumber / @Model.TotalPages
            </span>
            <ul class="pagination custom-pagination mb-0">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                    </li>
                }

                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
</div>

<style>
    /* Sử dụng lại các biến CSS từ Layout */

    /* Input & Nút bấm */
    .custom-input {
        background-color: #f8f9fa;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 10px 15px;
        font-size: 14px;
        transition: all 0.3s;
        box-shadow: none !important;
    }

        .custom-input:focus {
            background-color: #fff;
            border-color: var(--primary-accent);
        }

    .input-icon {
        position: relative;
    }

    .custom-btn-submit {
        background-color: var(--primary-accent);
        border: none;
        color: white;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .custom-btn-submit:hover {
            background-color: var(--primary-accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(0, 224, 184, 0.2);
        }

    /* Bảng dữ liệu (Table) */
    .custom-table {
        background: #fff;
    }

        .custom-table thead th {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #a1a5b7;
            background-color: #fcfcfc;
            border-bottom: 1px solid #edf2f4;
            padding: 15px 10px;
        }

        .custom-table tbody td {
            padding: 15px 10px;
            border-bottom: 1px solid #f4f6f8;
            vertical-align: middle;
        }

        .custom-table tbody tr {
            transition: background-color 0.2s;
        }

            .custom-table tbody tr:hover {
                background-color: #f8f9fa;
            }

    /* Nút thao tác trong bảng */
    .btn-action {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: none;
        transition: all 0.2s;
        background-color: #f1f3f9;
    }

        .btn-action:hover {
            background-color: #e4e6ef;
            transform: scale(1.05);
        }

    /* Phân trang (Pagination) */
    .custom-pagination .page-item .page-link {
        border: none;
        color: #5e6278;
        background-color: transparent;
        border-radius: 8px;
        margin: 0 2px;
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 500;
        font-size: 14px;
        transition: all 0.2s;
    }

    .custom-pagination .page-item:not(.active) .page-link:hover {
        background-color: #f1f3f9;
        color: var(--primary-accent);
    }

    .custom-pagination .page-item.active .page-link {
        background-color: var(--primary-accent);
        color: #fff;
        box-shadow: 0 4px 10px rgba(0, 224, 184, 0.2);
    }

    .fs-7 {
        font-size: 0.875rem;
    }

    /* Đảm bảo icon lịch trong thẻ input type="date" không bị lệch */
    input[type="date"].custom-input::-webkit-calendar-picker-indicator {
        cursor: pointer;
        opacity: 0.6;
        transition: 0.2s;
    }

        input[type="date"].custom-input::-webkit-calendar-picker-indicator:hover {
            opacity: 1;
        }

    /* Trên màn hình nhỏ, ô filter sẽ chiếm toàn bộ chiều ngang */

</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    });
</script>