@model StudentManagement.MVC.Models.Students.StudentVm

<style>

    .details-page {
        background: #e9e5df;
        padding: 40px;
        border-radius: 10px;
    }

    .profile-img {
        width: 62%;
        border-radius: 6px;
    }

    .name {
        font-size: 60px;
        font-weight: 600;
        color: #5b5248;
    }

    .job {
        letter-spacing: 4px;
        font-size: 14px;
        margin-top: 20px;
        color: #6c6359;
    }

    .desc {
        margin-top: 25px;
        font-size: 16px;
        color: #6c6359;
        line-height: 1.8;
    }

</style>

<div class="details-page">

    <div class="container">

        <div class="row align-items-center">

            <!-- LEFT IMAGE -->

            <div class="col-md-6">

                <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e"
                     class="profile-img" />

            </div>


            <!-- RIGHT CONTENT -->

            <div class="col-md-6">

                <h1 class="name">@Model.Name</h1>

                <div class="job">
                    SINH VIÊN
                </div>

                <div class="desc">

                    <p>
                        Giới tính:
                        <strong>@(Model.Gender ? "Nam" : "Nữ")</strong>
                    </p>

                    <p>
                        Ngày sinh:
                        <strong>@Model.Dob?.ToString("dd/MM/yyyy")</strong>
                    </p>

                    <p>
                        Điểm GPA:
                        <strong>@Model.Gpa</strong>
                    </p>

                    <p>
                        Phòng ban:
                        <strong>@Model.DepartmentId</strong>
                    </p>

                    <p class="mt-4">
                        Sinh viên đang theo học tại hệ thống quản lý sinh viên.
                        Trang này hiển thị thông tin chi tiết của sinh viên trong hệ thống.
                    </p>

                    <a asp-action="Index" class="btn btn-dark mt-3">
                        Quay lại danh sách
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>