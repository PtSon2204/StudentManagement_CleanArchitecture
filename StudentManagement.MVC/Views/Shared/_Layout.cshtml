@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Management System</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root {
            /* Hệ thống màu sắc mới hiện đại hơn cho năm 2026 */
            --bg-body: #f1f3f9; /* Nền chính màu xám cực nhẹ */
            --bg-sidebar: #1e1e2d; /* Nền menu màu chàm đậm (gần như đen) */
            --primary-accent: #00e0b8; /* Màu nhấn xanh ngọc tươi */
            --primary-accent-hover: #00c4a1; /* Màu nhấn khi hover */
            --text-main: #2b2d42; /* Chữ chính màu xám đậm */
            --text-on-sidebar: #a1a5b7; /* Chữ trên nền menu */
            --card-shadow: 0 5px 15px rgba(0, 0, 0, 0.05); /* Bóng đổ nhẹ cho cards */
            --border-radius-lg: 16px; /* Góc bo tròn lớn hơn cho thẻ */
        }

        body {
            background-color: var(--bg-body);
            font-family: 'Inter', sans-serif; /* Sử dụng font chữ hiện đại */
            color: var(--text-main);
            margin: 0;
            display: flex;
            min-height: 100vh;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: 280px;
            background: var(--bg-sidebar);
            display: flex;
            flex-direction: column;
            border-right: none;
            position: fixed;
            top: 0;
            bottom: 0;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 25px;
            font-size: 22px;
            font-weight: 700;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            margin-bottom: 20px;
        }

        .sidebar .menu-title {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #565e7a;
            padding: 15px 25px 5px 25px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            margin: 4px 15px;
            color: var(--text-on-sidebar);
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            font-size: 15px;
            transition: all 0.3s ease;
        }

            .sidebar a i {
                font-size: 18px;
                margin-right: 12px;
                transition: color 0.3s ease;
            }

            .sidebar a:hover {
                background: rgba(255, 255, 255, 0.05);
                color: #ffffff;
            }

                .sidebar a:hover i {
                    color: var(--primary-accent);
                }

            /* Menu đang hoạt động: Nổi bật với viền và màu nhấn */
            .sidebar a.active {
                background: rgba(255, 255, 255, 0.08);
                color: #ffffff;
                border-left: 4px solid var(--primary-accent);
                border-top-left-radius: 0;
                border-bottom-left-radius: 0;
            }

                .sidebar a.active i {
                    color: var(--primary-accent);
                }

        /* Phần Cài đặt và Đăng xuất tách biệt ở phía dưới */
        .sidebar-footer {
            margin-top: auto;
            padding-bottom: 15px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        /* --- TOPBAR --- */
        .topbar {
            background: #ffffff;
            border-bottom: none;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-left: 280px;
            width: calc(100% - 280px);
            position: sticky;
            top: 0;
            z-index: 999;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }

        .topbar-search {
            width: 300px;
            position: relative;
        }

            .topbar-search input {
                background: var(--bg-body);
                border: none;
                border-radius: 8px;
                padding: 10px 15px 10px 35px;
                width: 100%;
                font-size: 14px;
            }

            .topbar-search i {
                position: absolute;
                left: 12px;
                top: 11px;
                color: #a1a5b7;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .notification-btn {
            position: relative;
            cursor: pointer;
            font-size: 18px;
            color: #a1a5b7;
        }

        .notification-badge {
            position: absolute;
            top: 2px;
            right: -1px;
            width: 7px;
            height: 7px;
            background-color: #ef233c;
            border-radius: 50%;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .user-avatar {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: rgba(67, 97, 238, 0.1);
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        /* --- NỘI DUNG CHÍNH --- */
        .content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 30px;
            min-height: 100vh;
        }

        /* Các thẻ Dashboard hiện đại: góc bo tròn lớn và bóng đổ nhẹ */
        .card-dashboard {
            border: none;
            border-radius: var(--border-radius-lg);
            box-shadow: var(--card-shadow);
            background: #ffffff;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .card-dashboard:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            }
    </style>
</head>

<body>

    <div class="sidebar">
        <div class="sidebar-brand">
            <span>🎓</span> SMS Admin
        </div>

        <div class="menu-title">MENU CHÍNH</div>

        <a class="@(controller == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
            <i class="bi bi-grid"></i> Dashboard
        </a>

        <a class="@(controller == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
            <i class="bi bi-people"></i> Người dùng
        </a>

        <a class="@(controller == "Student" ? "active" : "")" asp-controller="Student" asp-action="Index">
            <i class="bi bi-mortarboard"></i> Sinh viên
        </a>

        <a class="@(controller == "Department" ? "active" : "")" asp-controller="Department" asp-action="Index">
            <i class="bi bi-building"></i> Phòng ban
        </a>

        <a class="@(controller == "Role" ? "active" : "")" asp-controller="Role" asp-action="Index">
            <i class="bi bi-shield-lock"></i> Vai trò
        </a>

        <div class="sidebar-footer">
            <div class="menu-title mt-3">HỆ THỐNG</div>
            <a>
                <i class="bi bi-gear"></i> Cài Đặt
            </a>

            <a class="text-danger mt-1">
                <i class="bi bi-box-arrow-right text-danger"></i> Đăng Xuất
            </a>
        </div>
    </div>

    <div style="width: 100%;">

        <div class="topbar">
            <div class="topbar-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Tìm kiếm sinh viên...">
            </div>

            <div class="topbar-right">
                <div class="notification-btn">
                    <i class="bi bi-bell"></i>
                    <span class="notification-badge"></span>
                </div>

                <div class="user-profile">
                    <div class="user-avatar">A</div>
                    <div>
                        <div class="fw-semibold" style="font-size: 14px;">Admin</div>
                        <div class="text-muted" style="font-size: 12px;">Hệ thống</div>
                    </div>
                    <i class="bi bi-chevron-down text-muted fs-8ms-1"></i>
                </div>
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>